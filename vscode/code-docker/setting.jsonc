{
  	"editor.fontLigatures": true, // editor ligature
	"editor.fontFamily": "'KawaiiMono', 'monospace'", // editor fonts

	"editor.fontSize": 25,
	"terminal.integrated.fontSize": 18,

  	"editor.cursorBlinking": "solid", // 커서 깜빡임 유형
	"editor.cursorStyle": "block", // 커서모양
	"editor.hover.enabled": "on",

  	"git.confirmSync": false, // sync 확인해야하는 여부
	"git.autofetch": true, // 자동 fetch (pull 확인)
	"git.enableSmartCommit": true, // stage 빈상태로 커밋하면 git add . 먼저 실행

  	"editor.guides.bracketPairs": "active", // 괄호 가이드 선 보여주기
	"editor.matchBrackets": "always", // 일치하는 괄호를 하이라이팅 해줌
	"editor.guides.highlightActiveBracketPair": true,
	"editor.bracketPairColorization.enabled": true,

	"editor.stickyTabStops": true, // 스페이스를 탭문자처럼 이동시킴
	"editor.renderLineHighlight": "all", // 현재 줄 강조 표시
	"editor.inlineSuggest.enabled": true,
	"editor.rulers": [80, 90, 100],
	"files.autoSave": "off",
	"explorer.sortOrder": "type",

	"chat.mcp.discovery.enabled": {
		"claude-desktop": false,
		"windsurf": false,
		"cursor-global": false,
		"cursor-workspace": false
	},
	"github.copilot.enable": {
		"*": false,
		"plaintext": false,
		"markdown": false,
		"scminput": false
	},

	"workbench.activityBar.location": "bottom", // 액티비티바 (오른쪽 패널 탭) 위치
	"window.menuBarVisibility": "classic",
	
	"workbench.colorTheme": "Dark Modern",
	"workbench.iconTheme": "material-icon-theme",

	"workbench.editor.empty.hint": "hidden",
	"chat.agent.maxRequests": 30,

	"files.associations": {
        ".luaurc": "jsonc"
    },

	"[luau]": {
		"editor.defaultFormatter": "JohnnyMorganz.stylua"
	},

	"files.associations": {
        "*.luau": "luau",
        "*.lua": "lua",
        ".luaurc": "json",
    },

	"luau-lsp.types.definitionFiles": [ "luau" ],
	"luau-lsp.inlayHints.functionReturnTypes": true,
	"luau-lsp.inlayHints.hideHintsForErrorTypes": true,
	"luau-lsp.inlayHints.parameterTypes": true,
	"luau-lsp.inlayHints.variableTypes": true,
	"luau-lsp.completion.imports.enabled": true,
	"luau-lsp.inlayHints.parameterNames": "all",

	"terminal.integrated.copyOnSelection": true,

	"haskell.manageHLS": "GHCup",

	"Lua.diagnostics.disable": [
		"unused-function",
		"unused-label",
		"unused-local",
		"unused-vararg",
	],
	"Lua.runtime.builtin": {
        "ffi": "enable"
    },

	"[rust]": {
		"editor.formatOnSave": true,
		"editor.formatOnType": true
	},

	"editor.acceptSuggestionOnEnter": "on",
	"vim.cursorStylePerMode.insert": "line",
	"vim.cursorStylePerMode.normal": "block",
	"vim.cursorStylePerMode.replace": "block",
	"vim.cursorStylePerMode.visual": "block",
	"vim.cursorStylePerMode.visualline": "block",
	"vim.cursorStylePerMode.visualblock": "block",
	"vim.statusBarColorControl": true,
	"vim.startInInsertMode": false,
	"vim.useSystemClipboard": false, // 아니 "+p 쓰면 되지않나요? 그러게요
	"vim.handleKeys": {
		"<C-w>": true,
		"ctrl+w": true,
		"<Tab>": true,
	},
	"vim.normalModeKeyBindingsNonRecursive": [
		{
			"before": ["K"],
			"commands": ["editor.action.showHover"]
		},
		{
			"before": ["u"],
			"commands": ["undo"]
		},
		{
			"before": ["<C-r>"],
			"commands": ["redo"]
		},
		{
			"before": ["<Tab>"],
			"after": ["<C-n>"]
		}
	],

	"workbench.colorCustomizations": {
		"menu.background": "#18161b",
		"menu.separatorBackground": "#3c3c3c",
		"panel.border": "#303547",
		"sideBar.border": "#303547",
		"titleBar.border": "#2a2e3b",
		"statusBar.border": "#303547",
		"statusBarItem.remoteBackground": "#b68cee",
		"statusBarItem.remoteForeground": "#300f5b",
		"titleBar.activeBackground": "#0b0716",
		"titleBar.inactiveBackground": "#0b0716",
		"titleBar.activeForeground": "#aba0c9",
		"minimap.background": "#0b0a0e",
		"editorStickyScroll.background": "#0a0c15",
		"widget.shadow": "#000000b8",
		"editorCursor.background": "#290022",
		"editorCursor.foreground": "#f4abff",
		"terminalCursor.foreground": "#f6bdff",
		"editor.lineHighlightBackground": "#27192e",
		"editor.selectionBackground": "#a41eb858",
		"editorRuler.foreground": "#ffffff1f",
		"editorBracketHighlight.foreground1": "#d6c8c8",
		"editorBracketHighlight.foreground2": "#b38ca6",
		"editorBracketHighlight.foreground3": "#9573b8",
		"editorBracketHighlight.foreground4": "#ab82d9",
		"editorBracketHighlight.foreground5": "#7b88cc",
		"editorBracketHighlight.foreground6": "#8f5c6b",
		"editorBracketHighlight.unexpectedBracket.foreground": "#db6165",
		"terminal.selectionBackground": "#f196ff54",
		"terminal.background": "#0b0a0e",
		"terminal.ansiWhite": "#F8F8F2",
		"terminal.ansiBlack": "#21222C",
		"terminal.ansiBlue": "#BD93F9",
		"terminal.ansiCyan": "#8BE9FD",
		"terminal.ansiGreen": "#50FA7B",
		"terminal.ansiMagenta": "#FF79C6",
		"terminal.ansiRed": "#FF5555",
		"terminal.ansiYellow": "#F1FA8C",
		"terminal.ansiBrightWhite": "#FFFFFF",
		"terminal.ansiBrightBlack": "#6272A4",
		"terminal.ansiBrightBlue": "#D6ACFF",
		"terminal.ansiBrightCyan": "#A4FFFF",
		"terminal.ansiBrightGreen": "#69FF94",
		"terminal.ansiBrightMagenta": "#FF92DF",
		"terminal.ansiBrightRed": "#FF6E6E",
		"terminal.ansiBrightYellow": "#FFFFA5",
		"statusBar.background": "#5f00af",
		"statusBar.noFolderBackground": "#5f00af",
		"statusBar.debuggingBackground": "#5f00af",
		"statusBar.foreground": "#ffffff",
		"statusBar.debuggingForeground": "#ffffff",

		"editor.foreground": "#d6c8c8",
		"editorCursor.foreground": "#d6c8c8",

		// 라인 넘버
		"editorLineNumber.foreground": "#625962",
		"editorLineNumber.activeForeground": "#b8aaaa",

		// 선택 영역 (Visual mode) 및 검색
		"editor.selectionBackground": "#382d38",
		"editor.findMatchBackground": "#c985c9",
		"editor.findMatchHighlightBackground": "#a66ba6",

		// 에러, 경고, 정보 등 (LSP 진단)
		"editorError.foreground": "#bf4040",
		"editorWarning.foreground": "#b39666",
		"editorInfo.foreground": "#7b88cc",
		"editorHint.foreground": "#a68ca6",

		// 팝업 메뉴 (자동완성 등 Pmenu)
		"editorSuggestWidget.background": "#625962",
		"editorSuggestWidget.foreground": "#d6c8c8",
		"editorSuggestWidget.selectedBackground": "#a68ca6",

		// Git 변경 사항 (에디터 좌측 Gutter)
		"editorGutter.addedBackground": "#6db38a",
		"editorGutter.modifiedBackground": "#b39666",
		"editorGutter.deletedBackground": "#bf4040"
	},
	"editor.tokenColorCustomizations": {
		"textMateRules": [
			{
				"name": "Comments",
				"scope": [
					"comment",
					"punctuation.definition.comment"
				],
				"settings": {
					"foreground": "#625962"
				}
			},
			{
				"name": "Strings",
				"scope": "string",
				"settings": {
					"foreground": "#7b88cc"
				}
			},
			{
				"name": "String Escape",
				"scope": "constant.character.escape",
				"settings": {
					"foreground": "#9aa7ff"
				}
			},
			{
				"name": "Characters",
				"scope": "constant.character",
				"settings": {
					"foreground": "#5e6cb3",
					"fontStyle": "italic"
				}
			},
			{
				"name": "Numbers & Floats",
				"scope": "constant.numeric",
				"settings": {
					"foreground": "#ab82d9"
				}
			},
			{
				"name": "Constants & Booleans",
				"scope": [
					"constant.language",
					"constant.other"
				],
				"settings": {
					"foreground": "#9573b8"
				}
			},
			{
				"name": "Functions & Methods",
				"scope": [
					"entity.name.function",
					"support.function",
					"meta.function-call"
				],
				"settings": {
					"foreground": "#948b8b"
				}
			},
			{
				"name": "Keywords & Statements",
				"scope": [
					"keyword",
					"keyword.control"
				],
				"settings": {
					"foreground": "#b38ca6"
				}
			},
			{
				"name": "Imports",
				"scope": [
					"keyword.control.import",
					"storage.modifier.import"
				],
				"settings": {
					"foreground": "#b38ca6"
				}
			},
			{
				"name": "Conditionals & PreProcessors",
				"scope": [
					"keyword.control.conditional",
					"keyword.control.directive"
				],
				"settings": {
					"foreground": "#b38ca6"
				}
			},
			{
				"name": "Operators",
				"scope": "keyword.operator",
				"settings": {
					"foreground": "#8f5c6b"
				}
			},
			{
				"name": "Types & Classes",
				"scope": [
					"entity.name.type",
					"entity.name.class",
					"support.type",
					"support.class"
				],
				"settings": {
					"foreground": "#c28498"
				}
			},
			{
				"name": "Storage Classes",
				"scope": "storage.modifier",
				"settings": {
					"foreground": "#a86d81"
				}
			},
			{
				"name": "Variables & Identifiers",
				"scope": [
					"variable",
					"variable.other",
					"variable.parameter",
				],
				"settings": {
					"foreground": "#d6c8c8"
				}
			},
			{
				"name": "Delimiters & Punctuation",
				"scope": [
					"punctuation.separator",
					"punctuation.terminator",
					"punctuation.definition.parameters",
					"punctuation.definition.array",
					"punctuation.definition.dictionary"
				],
				"settings": {
					"foreground": "#b0a4a4"
				}
			},
			{
				"name": "Regex",
				"scope": "string.regexp",
				"settings": {
					"foreground": "#caa6ff"
				}
			},
			{
				"name": "Attributes (HTML / JSX / TSX)",
				"scope": "entity.other.attribute-name",
				"settings": {
					"foreground": "#b38ca6"
				}
			},
			{
				"name": "JSON Keys",
				"scope": [
					"support.type.property-name.json",
					"meta.object-literal.key"
				],
				"settings": {
					"foreground": "#d6c8c8"
				}
			},
			{
				"name": "Object Keys",
				"scope": [
					"variable.other.property",
					"meta.object-literal.key",
					"support.type.property-name"
				],
				"settings": {
					"foreground": "#d6c8c8"
				}
			},
			{
				"name": "Markdown/Markup Titles",
				"scope": [
					"markup.heading",
					"entity.name.section"
				],
				"settings": {
					"foreground": "#948b8b"
				}
			},
			{
				"name": "Markdown Emphasis",
				"scope": [
					"markup.bold",
					"markup.italic"
				],
				"settings": {
					"foreground": "#b0a4a4",
					"fontStyle": "italic"
				}
			},
			{
				"name": "Diff",
				"scope": [
					"markup.inserted",
					"markup.deleted"
				],
				"settings": {
					"foreground": "#8f5c6b"
				}
			},
			{
				"name": "Invalid / Broken",
				"scope": "invalid",
				"settings": {
					"foreground": "#ff6b6b"
				}
			}
			{
				"name": "Constants (UPPER_CASE / SNAKE_CASE)",
				"scope": [
					"variable.other.constant",
					"entity.name.constant",
					"constant.other.caps",
					"support.constant",
					"constant.language"
				],
				"settings": {
					"foreground": "#b38ca6",
				}
			}
			{
				"name": "Enums",
				"scope": [
					"entity.name.enum",
					"variable.other.enummember"
				],
				"settings": {
					"foreground": "#c28498"
				}
			}
			{
				"name": "Namespace / Modules",
				"scope": [
					"entity.name.namespace",
					"support.module"
				],
				"settings": {
					"foreground": "#a99999"
				}
			}
		]
	},
}
