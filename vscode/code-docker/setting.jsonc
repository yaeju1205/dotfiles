		// 라인 넘버
		"editorLineNumber.foreground": "#625962",
		"editorLineNumber.activeForeground": "#b8aaaa",

		// 선택 영역 (Visual mode) 및 검색
		"editor.selectionBackground": "#382d38",
		"editor.findMatchBackground": "#c985c9",
		"editor.findMatchHighlightBackground": "#a66ba6",

		// 에러, 경고, 정보 등 (LSP 진단)
		"editorError.foreground": "#bf4040",
		"editorWarning.foreground": "#b39666",
		"editorInfo.foreground": "#7b88cc",
		"editorHint.foreground": "#a68ca6",

		// 팝업 메뉴 (자동완성 등 Pmenu)
		"editorSuggestWidget.background": "#625962",
		"editorSuggestWidget.foreground": "#d6c8c8",
		"editorSuggestWidget.selectedBackground": "#a68ca6",

		// Git 변경 사항 (에디터 좌측 Gutter)
		"editorGutter.addedBackground": "#6db38a",
		"editorGutter.modifiedBackground": "#b39666",
		"editorGutter.deletedBackground": "#bf4040"
	},
	"editor.tokenColorCustomizations": {
		"textMateRules": [
			{
				"name": "Comments",
				"scope": [
					"comment",
					"punctuation.definition.comment"
				],
				"settings": {
					"foreground": "#625962"
				}
			},
			{
				"name": "Strings",
				"scope": "string",
				"settings": {
					"foreground": "#7b88cc"
				}
			},
			{
				"name": "String Escape",
				"scope": "constant.character.escape",
				"settings": {
					"foreground": "#9aa7ff"
				}
			},
			{
				"name": "Characters",
				"scope": "constant.character",
				"settings": {
					"foreground": "#5e6cb3",
					"fontStyle": "italic"
				}
			},
			{
				"name": "Numbers & Floats",
				"scope": "constant.numeric",
				"settings": {
					"foreground": "#ab82d9"
				}
			},
			{
				"name": "Constants & Booleans",
				"scope": [
					"constant.language",
					"constant.other"
				],
				"settings": {
					"foreground": "#9573b8"
				}
			},
			{
				"name": "Functions & Methods",
				"scope": [
					"entity.name.function",
					"support.function",
					"meta.function-call"
				],
				"settings": {
					"foreground": "#948b8b"
				}
			},
			{
				"name": "Keywords & Statements",
				"scope": [
					"keyword",
					"keyword.control"
				],
				"settings": {
					"foreground": "#b38ca6"
				}
			},
			{
				"name": "Imports",
				"scope": [
					"keyword.control.import",
					"storage.modifier.import"
				],
				"settings": {
					"foreground": "#b38ca6"
				}
			},
			{
				"name": "Conditionals & PreProcessors",
				"scope": [
					"keyword.control.conditional",
					"keyword.control.directive"
				],
				"settings": {
					"foreground": "#b38ca6"
				}
			},
			{
				"name": "Operators",
				"scope": "keyword.operator",
				"settings": {
					"foreground": "#8f5c6b"
				}
			},
			{
				"name": "Types & Classes",
				"scope": [
					"entity.name.type",
					"entity.name.class",
					"support.type",
					"support.class"
				],
				"settings": {
					"foreground": "#c28498"
				}
			},
			{
				"name": "Storage Classes",
				"scope": "storage.modifier",
				"settings": {
					"foreground": "#a86d81"
				}
			},
			{
				"name": "Variables & Identifiers",
				"scope": [
					"variable",
					"variable.other",
					"variable.parameter"
				],
				"settings": {
					"foreground": "#d6c8c8"
				}
			},
			{
				"name": "Delimiters & Punctuation",
				"scope": [
					"punctuation.separator",
					"punctuation.terminator",
					"punctuation.definition.parameters",
					"punctuation.definition.array",
					"punctuation.definition.dictionary"
				],
				"settings": {
					"foreground": "#b0a4a4"
				}
			},
			{
				"name": "Regex",
				"scope": "string.regexp",
				"settings": {
					"foreground": "#caa6ff"
				}
			},
			{
				"name": "Attributes (HTML / JSX / TSX)",
				"scope": "entity.other.attribute-name",
				"settings": {
					"foreground": "#b38ca6"
				}
			},
			{
				"name": "JSON Keys",
				"scope": [
					"support.type.property-name.json",
					"meta.object-literal.key"
				],
				"settings": {
					"foreground": "#d6c8c8"
				}
			},
			{
				"name": "Markdown/Markup Titles",
				"scope": [
					"markup.heading",
					"entity.name.section"
				],
				"settings": {
					"foreground": "#948b8b"
				}
			},
			{
				"name": "Markdown Emphasis",
				"scope": [
					"markup.bold",
					"markup.italic"
				],
				"settings": {
					"foreground": "#b0a4a4",
					"fontStyle": "italic"
				}
			},
			{
				"name": "Diff",
				"scope": [
					"markup.inserted",
					"markup.deleted"
				],
				"settings": {
					"foreground": "#8f5c6b"
				}
			},
			{
				"name": "Invalid / Broken",
				"scope": "invalid",
				"settings": {
					"foreground": "#ff6b6b"
				}
			}
			{
				"name": "Brackets & Parentheses",
				"scope": [
					"punctuation.section.parens.begin",
					"punctuation.section.parens.end",
					"punctuation.section.brackets.begin",
					"punctuation.section.brackets.end",
					"punctuation.section.block.begin",
					"punctuation.section.block.end",
					"meta.brace.round",
					"meta.brace.square",
					"meta.brace.curly"
				],
				"settings": {
					"foreground": "#b0a4a4"
				}
			}
			{
				"name": "Constants (UPPER_CASE / SNAKE_CASE)",
				"scope": [
					"variable.other.constant",
					"entity.name.constant",
					"constant.other.caps",
					"support.constant",
					"constant.language"
				],
				"settings": {
					"foreground": "#b38ca6",
				}
			}
		]
	},
	"github.copilot.enable": {
		"*": false,
		"plaintext": false,
		"markdown": false,
		"scminput": false
	},
}
